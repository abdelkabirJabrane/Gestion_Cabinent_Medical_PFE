pipeline {
    agent any

    environment {
        SERVICE_NAME    = "ai-service"
        SONAR_HOST_URL  = "http://host.docker.internal:9005"
        SONAR_PROJECT   = "medicab-ai-service"
        DOCKER_REGISTRY = "abdojab"
    }

    stages {

        stage('Install Dependencies') {
            steps {
                dir("${env.SERVICE_NAME}") {
                    sh '''
                        python3 -m venv venv || true
                        . venv/bin/activate
                        python -m pip install --upgrade pip || true
                        pip install -r requirements.txt
                    '''
                }
            }
        }

        stage('Test (PyTest)') {
            steps {
                dir("${env.SERVICE_NAME}") {
                    sh '''
                        . venv/bin/activate
                        pytest tests/ --disable-warnings --maxfail=1
                    '''
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${env.SERVICE_NAME}") {
                    withSonarQubeEnv('sonarqube') {
                        withCredentials([string(credentialsId: 'tockensonarqube', variable: 'SONAR_TOKEN')]) {
                            sh """
                                sonar-scanner \
                                  -Dsonar.projectKey=${SONAR_PROJECT} \
                                  -Dsonar.sources=. \
                                  -Dsonar.host.url=${SONAR_HOST_URL} \
                                  -Dsonar.login=${SONAR_TOKEN}
                            """
                        }
                    }
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                dir("${env.SERVICE_NAME}") {
                    sh """
                        docker build -t ${DOCKER_REGISTRY}/${SERVICE_NAME}:latest .
                    """

                    withCredentials([usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        sh """
                            echo ${DOCKER_PASS} | docker login -u ${DOCKER_USER} --password-stdin
                            docker push ${DOCKER_REGISTRY}/${SERVICE_NAME}:latest
                        """
                    }
                }
            }
        }

        stage('Deploy to Minikube K8s') {
            steps {
                sh """
                    kubectl rollout restart deployment/${SERVICE_NAME} -n medicab || echo "Deployment not found"
                """
            }
        }
    }

    post {
        success {
            echo "Pipeline ${SERVICE_NAME} SUCCESS"
        }
        failure {
            echo "Pipeline ${SERVICE_NAME} FAILED"
        }
    }
}
