pipeline {
    agent any

    environment {
        SERVICE_NAME    = "ai-service"
        SONAR_HOST_URL  = "http://host.docker.internal:9005"
        SONAR_PROJECT   = "medicab"
        DOCKER_REGISTRY = "abdojab"
    }

    stages {

        stage('Test (PyTest)') {
            steps {
                dir("${env.SERVICE_NAME}") {
                    sh 'python3 -m pip install --break-system-packages -r requirements.txt'
                    sh 'python3 -m pytest tests/ --disable-warnings || echo "Tests optionnels terminés"'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonarqube') {
                    dir("${env.SERVICE_NAME}") {
                        sh """
                            sonar-scanner \
                            -Dsonar.projectKey=${env.SONAR_PROJECT}-${env.SERVICE_NAME} \
                            -Dsonar.sources=. \
                            -Dsonar.host.url=${env.SONAR_HOST_URL}
                        """
                    }
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                dir("${env.SERVICE_NAME}") {
                    sh "docker build -t ${env.DOCKER_REGISTRY}/${env.SERVICE_NAME}:latest ."

                    withCredentials([usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        passwordVariable: 'DOCKER_PASS',
                        usernameVariable: 'DOCKER_USER'
                    )]) {
                        sh "echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin"
                        sh "docker push ${env.DOCKER_REGISTRY}/${env.SERVICE_NAME}:latest"
                    }
                }
            }
        }

        stage('Deploy to Minikube K8s') {
            steps {
                sh "kubectl rollout restart deployment/${env.SERVICE_NAME} -n medicab || echo 'Deploy not found yet'"
            }
        }
    }

    post {
        success {
            echo "Pipeline ${env.SERVICE_NAME} SUCCESS"
        }
        failure {
            echo "Pipeline ${env.SERVICE_NAME} FAILED"
        }
    }
}
