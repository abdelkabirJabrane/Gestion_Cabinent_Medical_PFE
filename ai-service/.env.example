# ============================================================
# MedAgent AI Service — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# Groq API (FREE — https://console.groq.com)
# Gives: 14 400 req/day (LLM) + 20 000 min/day (Whisper)
GROQ_API_KEY=your_groq_api_key_here

# Gemini API (FREE — https://aistudio.google.com)  
# Fallback LLM if Groq is unavailable
GEMINI_API_KEY=your_gemini_api_key_here

# Service config
AI_SERVICE_PORT=8000
AI_SERVICE_HOST=0.0.0.0

# Primary LLM model
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# Whisper model (large-v3 is the most accurate)
GROQ_WHISPER_MODEL=whisper-large-v3

# Fallback Gemini model
GEMINI_MODEL=gemini-2.0-flash
